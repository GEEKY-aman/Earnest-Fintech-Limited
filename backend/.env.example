# MySQL Connection String (e.g., from PlanetScale, Aiven, or local MySQL)
DATABASE_URL="mysql://username:password@host:port/database_name"

# JWT Secrets (Generate strong random strings for production)
JWT_ACCESS_SECRET="earnest-access-secret-key-change-in-production"
JWT_REFRESH_SECRET="earnest-refresh-secret-key-change-in-production"

# Token Expiries
ACCESS_TOKEN_EXPIRY="15m"
REFRESH_TOKEN_EXPIRY="7d"

# Server Port (Local Dev)
PORT=5001

# CORS Origin (Frontend URL - Update this in Vercel to your deployed frontend URL)
CORS_ORIGIN="http://localhost:3000"
